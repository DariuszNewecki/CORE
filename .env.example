# CORE environment configuration — copy this file to .env:
#     cp .env.example .env
#
# These keys are read by src/shared/config.py via their exact names (single
# underscore, case-sensitive). The defaults below match docker-compose.yml, so
# the bundled Postgres + Qdrant work out of the box.

# --- Database (Postgres) — REQUIRED ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/core
DATABASE_POOL_SIZE=20
DATABASE_POOL_MAX_OVERFLOW=10
DATABASE_ECHO=false

# --- Vector store (Qdrant) — REQUIRED ---
QDRANT_URL=http://localhost:6333

# --- LLM — OPTIONAL ---
# Not needed for the offline audit or the deterministic consequence-chain demo.
# Set these to let CORE generate/remediate code with an LLM.
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL_NAME=

# --- Secrets at rest — OPTIONAL ---
# Encryption key for stored secrets. Generate a real base64-encoded 32-byte key
# for any non-throwaway use: python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
# CORE_MASTER_KEY=

# --- Misc ---
LOG_LEVEL=INFO
CORE_ENV=development
CORE_STRICT_MODE=false
