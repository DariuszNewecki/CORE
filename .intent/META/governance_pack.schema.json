{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "core.intent.governance_pack.schema.json",
    "title": "CORE Governance Pack Declaration",
    "description": "A self-contained, versioned bundle of rule definitions and enforcement mappings that external projects can adopt with a single declaration. Packs are the external-adoption unit: they replace manual rule authoring for common patterns.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "kind",
        "id",
        "version",
        "title",
        "description",
        "level",
        "rules",
        "enforcement_mappings"
    ],
    "properties": {
        "kind": {
            "type": "string",
            "const": "governance_pack",
            "description": "Document discriminator. Always 'governance_pack'."
        },
        "id": {
            "type": "string",
            "minLength": 3,
            "maxLength": 128,
            "description": "Stable pack identifier in 'vendor/name' form, e.g. 'core/starter-python'. Must be unique across the pack registry."
        },
        "version": {
            "type": "string",
            "minLength": 1,
            "maxLength": 32,
            "description": "Semver version string, e.g. '1.0.0'."
        },
        "title": {
            "type": "string",
            "minLength": 3,
            "maxLength": 256,
            "description": "Human-readable display name."
        },
        "description": {
            "type": "string",
            "minLength": 10,
            "maxLength": 4000,
            "description": "What this pack enforces and who should use it."
        },
        "target_language": {
            "type": "string",
            "maxLength": 32,
            "description": "Primary language this pack targets, e.g. 'python'."
        },
        "level": {
            "type": "string",
            "enum": ["starter", "intermediate", "strict"],
            "description": "Adoption complexity tier. starter: regex+AST only, zero-friction. intermediate: may require tooling (vulture, mypy). strict: full suite."
        },
        "compatibility_floor": {
            "type": "string",
            "maxLength": 32,
            "description": "Minimum core-runtime semver that ships this pack, e.g. '2.8.0'."
        },
        "supersedes": {
            "type": "string",
            "maxLength": 128,
            "description": "Pack ID this pack replaces on upgrade, e.g. 'core/starter-python' when moving to core/python-hygiene."
        },
        "rules": {
            "type": "array",
            "minItems": 1,
            "description": "Inline rule definitions. Authoritative source for this pack's rules — consumers do not need to author rule JSON.",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "id",
                    "statement",
                    "enforcement",
                    "authority",
                    "phase"
                ],
                "properties": {
                    "id": {
                        "type": "string",
                        "minLength": 3,
                        "maxLength": 256,
                        "description": "Rule identifier, e.g. 'starter.no_bare_except'. Must be unique across the combined rule + pack index."
                    },
                    "statement": {
                        "type": "string",
                        "minLength": 5,
                        "maxLength": 2000,
                        "description": "Human-readable rule statement in normative language (MUST / SHOULD)."
                    },
                    "enforcement": {
                        "type": "string",
                        "enum": ["blocking", "reporting", "advisory"],
                        "description": "Default enforcement level. Adopters may downgrade (but not upgrade) per-rule in their intent_tree.yaml packs: section."
                    },
                    "authority": {
                        "type": "string",
                        "enum": ["meta", "constitution", "policy", "code"],
                        "description": "Constitutional authority level."
                    },
                    "phase": {
                        "type": "string",
                        "description": "Workflow phase where this rule is checked."
                    },
                    "rationale": {
                        "type": "string",
                        "maxLength": 4000,
                        "description": "Why this rule exists. Optional but encouraged."
                    }
                }
            }
        },
        "enforcement_mappings": {
            "type": "object",
            "description": "Enforcement strategy for each rule, keyed by rule_id. Every rule listed in `rules` MUST have a corresponding entry here. The engine + params + scope determine HOW the rule is checked.",
            "additionalProperties": {
                "type": "object",
                "additionalProperties": false,
                "required": ["engine", "scope"],
                "properties": {
                    "engine": {
                        "type": "string",
                        "minLength": 1,
                        "description": "Execution engine: regex_gate, ast_gate, workflow_gate, advisory, passive_gate."
                    },
                    "params": {
                        "type": "object",
                        "description": "Engine-specific parameters."
                    },
                    "scope": {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["applies_to"],
                        "properties": {
                            "applies_to": {
                                "type": "array",
                                "minItems": 1,
                                "items": {"type": "string"},
                                "description": "Glob patterns for files this rule applies to."
                            },
                            "excludes": {
                                "type": "array",
                                "items": {"type": "string"},
                                "description": "Glob patterns to exclude."
                            }
                        }
                    }
                }
            }
        }
    }
}
