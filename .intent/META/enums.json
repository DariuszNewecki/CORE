{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CORE Intent Enumerations",
  "type": "object",
  "additionalProperties": false,

  "definitions": {

    "authority": {
      "type": "string",
      "enum": [
        "meta",
        "constitution",
        "policy",
        "code"
      ]
    },

    "phase": {
      "type": "string",
      "enum": [
        "interpret",
        "parse",
        "load",
        "audit",
        "runtime",
        "execution"
      ]
    },

    "strength": {
      "type": "string",
      "enum": [
        "blocking",
        "reporting",
        "advisory"
      ]
    },

    "artifact_status": {
      "type": "string",
      "enum": [
        "experimental",
        "active",
        "deprecated"
      ]
    },

    "workflow_ordering_mode": {
      "type": "string",
      "enum": [
        "single",
        "sequential",
        "parallel"
      ]
    }

  }
}
