# =============================================================================
# CORE — .gitignore
# Philosophy: version code and intent; exclude everything generated at runtime.
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.so
*.egg-info/
.mypy_cache/
.ruff_cache/
.venv/
dist/
build/

# -----------------------------------------------------------------------------
# Environment & secrets
# -----------------------------------------------------------------------------
# Env files — deny by default, allowlist explicit tracked fixtures
.env
.env.*
!.env.example
!.env.test

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
coverage.json

# -----------------------------------------------------------------------------
# Editors & OS
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
.claude/

# -----------------------------------------------------------------------------
# External mounts — symlinked, never versioned
# -----------------------------------------------------------------------------
ITAM

# -----------------------------------------------------------------------------
# Confidential commercial documents — strategic content, not for public repo
# -----------------------------------------------------------------------------
.specs/commercial/*
!.specs/commercial/.gitkeep

# -----------------------------------------------------------------------------
# GRC licensed catalog tier (ADR-116) — the proprietary moat. Populated by the
# private core-grc-catalogs repo (clone/mount), never committed to this public
# repo. Gitignored so neither a manual add nor the autonomous daemon can scoop
# licensed bytes into a public commit. The public tier IS versioned here.
# -----------------------------------------------------------------------------
grc-catalogs/licensed/

# -----------------------------------------------------------------------------
# Exploratory CORE-NG candidate spec — not binding for current CORE
# -----------------------------------------------------------------------------
.specs/core-ng/

# -----------------------------------------------------------------------------
# Runtime state — fully owned by CORE, never versioned
#   Exception: var/prompts/ is governance content (LLM prompt templates are
#   authored intent, not runtime output), tracked since #296.
# -----------------------------------------------------------------------------
var/*
!var/.gitkeep
!var/prompts/
!var/prompts/**
!var/d6-stage-c-migration-plan.md

# -----------------------------------------------------------------------------
# Autonomous workspace — ephemeral by definition
# -----------------------------------------------------------------------------
work/*
!work/.gitkeep

# -----------------------------------------------------------------------------
# Runtime output — generated at runtime, never versioned
# -----------------------------------------------------------------------------
logs/*
!logs/.gitkeep

reports/*
!reports/.gitkeep

tests/reports/

# -----------------------------------------------------------------------------
# Infrastructure scripts that are local/dev-only
# -----------------------------------------------------------------------------
infra/scripts/dev/
infra/scripts/archive/

# -----------------------------------------------------------------------------
# Demo recordings (keep docs, ignore binary recordings)
# -----------------------------------------------------------------------------
docs/demos/recordings/*.cast
docs/demos/recordings/*.mp4
docs/demos/recordings/*.gif

# -----------------------------------------------------------------------------
# Constitutional governance — keys are never versioned
# -----------------------------------------------------------------------------
.intent/keys/

# -----------------------------------------------------------------------------
# Temporary / legacy
# -----------------------------------------------------------------------------
*.log
*.jsonl
project_context.txt
.archive/
core.zip
node_modules/
